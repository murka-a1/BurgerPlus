<Page x:Class="BurgerPlus.Page.PageUsersAdd"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BurgerPlus.Page"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageUsersAdd">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="25*"/>
            <RowDefinition Height="36*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="137*"/>
            <ColumnDefinition Width="263*"/>
        </Grid.ColumnDefinitions>
        <Label Content="Редактирование пользователя" HorizontalAlignment="Center" Grid.Row="0" Grid.ColumnSpan="2" VerticalContentAlignment="Center" />
        <Label Grid.Column="0" Grid.Row="1" Content="Укажите пароль:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  />
        <Label Grid.Column="0" Grid.Row="2" Content="Укажите логин:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  />
        <Label Grid.Column="0" Grid.Row="3" Content="Укажите фамилию:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"   />
        <Label Grid.Column="0" Grid.Row="4" Content="Укажите имя:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  />
        <Label Grid.Column="0" Grid.Row="5" Content="Укажите отчество:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  />
        <Label Grid.Column="0" Grid.Row="6" Content="Укажите роль:" VerticalContentAlignment="Center" HorizontalContentAlignment="Left"  />


        <StackPanel Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Center" Margin="5">
            <Button x:Name="BtnSave"  Content="Сохранить" Click="BtnSave_Click" Height="40" Width="111" />
            <Button x:Name="BtnGoBack"  Content="Назад" Click="BtnGoBack_Click" Height="40" Width="111"  Margin="5"/>
        </StackPanel>

        <ComboBox Grid.Row="6" Grid.Column="1" x:Name="ComboRole"  Height="35" Width="499"  SelectedItem="{Binding Role}" DisplayMemberPath="Name"/>
        <TextBox x:Name="TxbLog" Grid.Row="1" Grid.Column="1" Height="35" Width="499" Text="{Binding Login}"/>
        <TextBox x:Name="TxbPass" Grid.Row="2" Grid.Column="1" Height="35" Width="499" Text="{Binding Password}"/>
        <TextBox x:Name="TxbLN" Grid.Row="3" Grid.Column="1" Height="35" Width="499" Text="{Binding LastName}"/>
        <TextBox x:Name="TxbFN" Grid.Row="4" Grid.Column="1" Height="35" Width="499" Text="{Binding FirstName}"/>
        <TextBox x:Name="TxbPatr" Grid.Row="5" Grid.Column="1" Height="35" Width="499" Text="{Binding Patronymic}"/>
    </Grid>
</Page>